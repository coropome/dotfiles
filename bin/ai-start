#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if [[ -L "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
fi
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"

# shellcheck source=/dev/null
source "$BIN_DIR/_ai_common"
REPO_ROOT="$(ai_repo_root "$BIN_DIR")"
TMUX_LAYOUT="$REPO_ROOT/tmux/layout.conf"

usage() {
  cat <<'EOF'
usage: ai-start [--repo PATH] [--stop]
EOF
}

repo_path=""
stop_requested=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      [[ $# -ge 2 ]] || { usage >&2; exit 2; }
      repo_path="$2"
      shift 2
      ;;
    --stop)
      stop_requested=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

target_repo="$(ai_target_repo_root "${repo_path:-$PWD}")"
window_name="$(
  awk -F= '/^AI_TMUX_WINDOW_NAME=/{print $2; found=1; exit} END { if (!found) print "" }' "$TMUX_LAYOUT"
)"
window_name="${window_name%\"}"
window_name="${window_name#\"}"
[[ -n "$window_name" ]] || window_name="workspace"
session_name="$(ai_session_name "$target_repo" "$TMUX_LAYOUT")"

if [[ $stop_requested -eq 1 ]]; then
  if tmux has-session -t "$session_name" >/dev/null 2>&1; then
    tmux kill-session -t "$session_name"
  fi
  exit 0
fi

if ! tmux has-session -t "$session_name" >/dev/null 2>&1; then
  tmux new-session -d -s "$session_name" -n "$window_name" -c "$target_repo"
  tmux send-keys -t "$session_name:$window_name.1" "$REPO_ROOT/bin/ai-context --repo $target_repo --show" C-m
fi

printf 'AI Dev OS workspace ready: %s\n' "$session_name"

if [[ -t 1 && -z "${TMUX:-}" ]]; then
  exec tmux attach-session -t "$session_name"
fi
