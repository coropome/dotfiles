#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if [[ -L "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
fi
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"

# shellcheck source=/dev/null
source "$BIN_DIR/_ai_common"
REPO_ROOT="$(ai_repo_root "$BIN_DIR")"
ai_load_os_layer "$BIN_DIR" "$REPO_ROOT"

target="${1:-}"
if [[ -z "$target" ]]; then
  echo "usage: ai-open <path-or-url>" >&2
  exit 2
fi

ai_os_open "$target"
