#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if [[ -L "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
fi
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"

# shellcheck source=/dev/null
source "$BIN_DIR/_ai_common"
REPO_ROOT="$(ai_repo_root "$BIN_DIR")"

usage() {
  cat <<'EOF'
usage: ai-init [--repo PATH] [--template starter]
EOF
}

target_path="$PWD"
template_name="starter"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      [[ $# -ge 2 ]] || { usage >&2; exit 2; }
      target_path="$2"
      shift 2
      ;;
    --template)
      [[ $# -ge 2 ]] || { usage >&2; exit 2; }
      template_name="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

if [[ "$template_name" != "starter" ]]; then
  echo "unsupported template: $template_name" >&2
  exit 2
fi

target_repo="$(ai_target_repo_root "$target_path")"
mkdir -p "$target_repo/.ai-dev-os" "$target_repo/prompts"

cat > "$target_repo/.ai-dev-os/agents.yml" <<'EOF'
agents:
  implementer:
    command: claude
    role: implementer
    prompt_file: prompts/review.prompt.yml
  reviewer:
    command: codex
    role: reviewer
    prompt_file: prompts/review.prompt.yml
EOF

cat > "$target_repo/.ai-dev-os/workflows.yml" <<'EOF'
workflows:
  code:
    default_agent: implementer
    description: Local project implementation workflow
  review:
    default_agent: reviewer
    description: Local project review workflow
EOF

cat > "$target_repo/prompts/review.prompt.yml" <<'EOF'
name: Project Review
description: Review a proposed change for regressions and rollout risk.
messages:
  - role: system
    content: |
      You are a careful software reviewer.
      Focus on regressions, risk, and missing tests.
  - role: user
    content: |
      Review this change:
      {{change_request}}
testData:
  - change_request: |
      Add a new CLI command that touches project bootstrap.
evaluators:
  - name: Mentions regression risk
    string:
      contains: risk
EOF

cat > "$target_repo/.ai-dev-os/README.md" <<EOF
# AI Dev OS Starter

This directory was generated by \`ai init\`.

## Generated Files

- \`.ai-dev-os/agents.yml\`
- \`.ai-dev-os/workflows.yml\`
- \`prompts/review.prompt.yml\`

## Vendor Trust Templates

- Claude: $REPO_ROOT/templates/ai-trust/claude-settings.json
- Codex: $REPO_ROOT/templates/ai-trust/codex-config.toml
- Gemini: $REPO_ROOT/templates/ai-trust/gemini-settings.json

Copy the template you need into vendor-native config instead of editing AI Dev OS shell code.
EOF

printf 'generated: %s/.ai-dev-os/agents.yml\n' "$target_repo"
printf 'generated: %s/.ai-dev-os/workflows.yml\n' "$target_repo"
printf 'generated: %s/prompts/review.prompt.yml\n' "$target_repo"
printf 'generated: %s/.ai-dev-os/README.md\n' "$target_repo"
