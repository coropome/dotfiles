#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if [[ -L "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
fi
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"

# shellcheck source=/dev/null
source "$BIN_DIR/_ai_common"
REPO_ROOT="$(ai_repo_root "$BIN_DIR")"

usage() {
  cat <<'EOF'
usage: ai-init [--repo PATH] [--template starter] [--no-github-actions] [--no-hosted-eval]
EOF
}

target_path="$PWD"
template_name="starter"
include_github_actions=1
include_hosted_eval=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      [[ $# -ge 2 ]] || { usage >&2; exit 2; }
      target_path="$2"
      shift 2
      ;;
    --template)
      [[ $# -ge 2 ]] || { usage >&2; exit 2; }
      template_name="$2"
      shift 2
      ;;
    --no-github-actions)
      include_github_actions=0
      include_hosted_eval=0
      shift
      ;;
    --no-hosted-eval)
      include_hosted_eval=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

if [[ "$template_name" != "starter" ]]; then
  echo "unsupported template: $template_name" >&2
  exit 2
fi

target_repo="$(ai_target_repo_root "$target_path")"
mkdir -p "$target_repo/.ai-dev-os" "$target_repo/.ai-dev-os/prompts"
if [[ $include_github_actions -eq 1 ]]; then
  mkdir -p "$target_repo/.github/workflows"
fi

write_if_missing() {
  local path="$1"
  local content="$2"

  if [[ -e "$path" ]]; then
    printf 'skipped: %s (already exists)\n' "$path"
    return 0
  fi

  printf '%s\n' "$content" > "$path"
  printf 'generated: %s\n' "$path"
}

write_template_if_missing() {
  local path="$1"
  local template_rel="$2"
  local template_path="$REPO_ROOT/$template_rel"

  if [[ -e "$path" ]]; then
    printf 'skipped: %s (already exists)\n' "$path"
    return 0
  fi

  if [[ ! -f "$template_path" ]]; then
    echo "missing starter template: $template_path" >&2
    exit 1
  fi

  cp "$template_path" "$path"
  printf 'generated: %s\n' "$path"
}

starter_readme_content() {
  cat <<EOF
# AI Dev OS Starter

This directory was generated by \`ai init\`.

## Generated Files

- \`.ai-dev-os/agents.yml\`
- \`.ai-dev-os/workflows.yml\`
- \`.ai-dev-os/prompts/implementer.md\`
- \`.ai-dev-os/prompts/reviewer.md\`
- \`.ai-dev-os/prompts/review.prompt.yml\`
EOF

  if [[ $include_github_actions -eq 1 ]]; then
    cat <<'EOF'
- `.github/workflows/ai-dev-os-pr.yml`
EOF
    if [[ $include_hosted_eval -eq 1 ]]; then
      cat <<'EOF'
- `.github/workflows/ai-dev-os-hosted-eval.yml`
EOF
    fi
  fi

  cat <<'EOF'

## Next Commands

```bash
ai workflows
ai agents
ai doctor
ai-agent --describe --workflow review
ai trust init claude --project
ai start
```

## Trust Setup

- repo-local starter: `ai trust init claude --project`
- other vendors: `ai trust init codex --project` / `ai trust init gemini --project`
- user-level replace with backup: `ai trust apply <vendor> --user`

If a workflow cannot launch as expected, run `ai doctor` first to inspect fallback resolution, prompt files, and trust/config gaps.

## If Something Fails

- local onboarding problem
  - use `ai doctor`
  - use this for workflow / prompt / trust / fallback / runtime config issues
- CI or runtime pinning problem
  - use the AI Dev OS runtime repo's `docs/42-github-actions.md`
  - use this when local onboarding works but generated GitHub Actions or runtime checkout does not
- system or bootstrap problem
  - run `make doctor` from the AI Dev OS runtime repo
  - use this for bootstrap / symlink / PATH / shell / system state issues
EOF

  if [[ $include_github_actions -eq 1 ]]; then
    cat <<'EOF'

## Which Path To Choose

- local-only first
  - stay on `ai doctor` / `ai workflows` / `ai start`
  - use this when CI is not the current problem
- PR CI next
  - keep `.github/workflows/ai-dev-os-pr.yml`
  - use this when you want prompt validation and CLI smoke on pull requests
EOF
    if [[ $include_hosted_eval -eq 1 ]]; then
      cat <<'EOF'
- hosted eval later
  - add `ai-dev-os-hosted-eval.yml` only after local and PR CI paths are stable
  - use this when hosted backend comparison is worth the extra credentials and policy surface
EOF
    else
      cat <<'EOF'
- hosted eval later
  - this run skipped hosted eval via `--no-hosted-eval`
  - add it only after local and PR CI paths are stable
  - use this when hosted backend comparison becomes worth the extra credentials and policy surface
EOF
    fi
    cat <<'EOF'
- runtime pinning
  - leave `AI_DEV_OS_RUNTIME_REPOSITORY` and `AI_DEV_OS_RUNTIME_REF` alone unless you need fork / branch / stability control
  - if CI fails but local onboarding works, check pinning before changing local starter files
EOF

    cat <<'EOF'

## Optional GitHub Actions Commands

```bash
sed -n '1,160p' .github/workflows/ai-dev-os-pr.yml
EOF
    if [[ $include_hosted_eval -eq 1 ]]; then
      cat <<'EOF'
gh workflow run ai-dev-os-hosted-eval.yml
EOF
    fi
    cat <<'EOF'
```

## GitHub Actions Starter

- `.github/workflows/ai-dev-os-pr.yml` validates prompt artifacts on pull requests and runs a starter smoke path
EOF
    if [[ $include_hosted_eval -eq 1 ]]; then
      cat <<'EOF'
- `.github/workflows/ai-dev-os-hosted-eval.yml` is manual opt-in for hosted evals
EOF
    else
      cat <<'EOF'
- hosted eval workflow generation was skipped for this run via `--no-hosted-eval`
EOF
    fi
    cat <<'EOF'
- both workflows check out the target repository and the default AI Dev OS runtime repo (`coropome/dotfiles`)
- set `AI_DEV_OS_RUNTIME_REPOSITORY` and `AI_DEV_OS_RUNTIME_REF` in those workflows to pin a fork, branch, or tag
EOF
  else
    cat <<'EOF'

## If Something Fails

- local onboarding problem
  - use `ai doctor`
  - use this for workflow / prompt / trust / fallback / runtime config issues
- CI or runtime pinning problem
  - use the AI Dev OS runtime repo's `docs/42-github-actions.md`
  - use this later when you choose to add generated CI or runtime pinning
- system or bootstrap problem
  - run `make doctor` from the AI Dev OS runtime repo
  - use this for bootstrap / symlink / PATH / shell / system state issues

## Which Path To Choose

- local-only first
  - this run skipped GitHub Actions via `--no-github-actions`
  - stay on `ai doctor` / `ai workflows` / `ai start`
- PR CI later
  - rerun `ai init` without `--no-github-actions` when pull-request smoke checks become useful
  - use this when you want prompt validation and CLI smoke on pull requests
- hosted eval much later
  - add it only after local onboarding and PR CI are both settled
  - use this when hosted backend comparison becomes worth the extra credentials and policy surface
- runtime pinning later
  - leave `AI_DEV_OS_RUNTIME_REPOSITORY` and `AI_DEV_OS_RUNTIME_REF` alone until you actually add generated CI
  - if local onboarding works, pinning is not the first thing to touch

## GitHub Actions Starter

GitHub Actions starter generation was skipped for this run via `--no-github-actions`.
EOF
  fi
}

write_if_missing \
  "$target_repo/.ai-dev-os/agents.yml" \
  "$(cat <<'EOF'
agents:
  local_implementer:
    provider: anthropic
    command: claude
    role: implementer
    description: Project-local implementation workflow
    prompt_file: .ai-dev-os/prompts/implementer.md
    prompt_handoff: append-system-prompt
    context_handoff: prompt
  local_reviewer:
    provider: openai
    command: codex
    role: reviewer
    description: Project-local review workflow
    prompt_file: .ai-dev-os/prompts/reviewer.md
    prompt_handoff: prompt
    context_handoff: prompt
  local_backup_reviewer:
    provider: google
    command: gemini
    role: reviewer
    description: Project-local review fallback when Codex is unavailable
    prompt_file: .ai-dev-os/prompts/reviewer.md
    prompt_handoff: prompt
    context_handoff: prompt
EOF
)"

write_if_missing \
  "$target_repo/.ai-dev-os/workflows.yml" \
  "$(cat <<'EOF'
workflows:
  code:
    default_agent: local_implementer
    description: Project-local implementation workflow
  review:
    default_agent: local_reviewer
    fallback_agents: local_backup_reviewer
    description: Project-local review workflow
EOF
)"

write_if_missing \
  "$target_repo/.ai-dev-os/prompts/implementer.md" \
  "$(cat <<'EOF'
# Project Implementer

Implement the requested change for this repository.

- prefer small, reviewable edits
- explain migration or rollout risk when behavior changes
- keep repository-local AI Dev OS config under `.ai-dev-os/`
EOF
)"

write_if_missing \
  "$target_repo/.ai-dev-os/prompts/reviewer.md" \
  "$(cat <<'EOF'
# Project Reviewer

Review the requested change for regressions, rollout risk, and missing tests.

- prioritize concrete bugs and behavioral regressions
- call out migration or operational risk when behavior changes
- prefer actionable remediation over vague style commentary
EOF
)"

write_if_missing \
  "$target_repo/.ai-dev-os/prompts/review.prompt.yml" \
  "$(cat <<'EOF'
name: Project Review
description: Review a proposed change for regressions and rollout risk.
messages:
  - role: system
    content: |
      You are a careful software reviewer.
      Focus on regressions, risk, and missing tests.
  - role: user
    content: |
      Review this change:
      {{change_request}}
testData:
  - change_request: |
      Add a project-local AI workflow scaffold for this repository.
evaluators:
  - name: Mentions rollout risk
    string:
      contains: risk
EOF
)"

write_if_missing \
  "$target_repo/.ai-dev-os/README.md" \
  "$(starter_readme_content)"

if [[ $include_github_actions -eq 1 ]]; then
  write_template_if_missing \
    "$target_repo/.github/workflows/ai-dev-os-pr.yml" \
    "templates/github-actions/ai-dev-os-pr.yml"

  if [[ $include_hosted_eval -eq 1 ]]; then
    write_template_if_missing \
      "$target_repo/.github/workflows/ai-dev-os-hosted-eval.yml" \
      "templates/github-actions/ai-dev-os-hosted-eval.yml"
  fi
fi

printf 'initialized repo: %s\n' "$target_repo"
printf 'next: ai workflows\n'
printf 'next: ai agents\n'
printf 'next: ai doctor\n'
printf 'next: ai trust init claude --project\n'
printf 'next: ai start\n'
if [[ $include_github_actions -eq 1 ]]; then
  printf "optional: sed -n '1,160p' .github/workflows/ai-dev-os-pr.yml\n"
  if [[ $include_hosted_eval -eq 1 ]]; then
    printf 'optional: gh workflow run ai-dev-os-hosted-eval.yml\n'
  fi
fi
