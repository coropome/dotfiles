#!/usr/bin/env bash
set -euo pipefail

# Attach to a tmux session. If none specified, pick interactively.

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux not found. Run: make install" >&2
  exit 1
fi

if [[ -n "${1:-}" ]]; then
  exec tmux attach -t "$1"
fi

sel=$("$(dirname "$0")/_tpick" "tmux attach> " || true)
[[ -z "$sel" ]] && exit 0
exec tmux attach -t "$sel"
